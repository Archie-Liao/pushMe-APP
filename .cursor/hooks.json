{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/run_capture_prompt.cmd",
        "timeout": 15
      }
    ],
    "afterAgentResponse": [
      {
        "command": ".cursor/hooks/run_capture_response.cmd",
        "timeout": 45
      }
    ],
    "sessionEnd": [
      {
        "command": ".cursor/hooks/run_session_end.cmd",
        "timeout": 15
      }
    ]
  }
}
