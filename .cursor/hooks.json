{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "python .cursor/hooks/capture_prompt.py",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python .cursor/hooks/capture_response.py",
        "timeout": 30
      }
    ],
    "sessionEnd": [
      {
        "command": "python .cursor/hooks/session_end.py",
        "timeout": 10
      }
    ]
  }
}
